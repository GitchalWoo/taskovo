<div style="margin: 0; padding: 0; background-color: #f4f4f7; width: 100%;">
  <div style="max-width: 560px; margin: 0 auto; padding: 24px 16px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.5; color: #1a1a1a;">

    {% if weekSummary %}
    <div style="margin-bottom: 24px; padding: 14px 16px; background-color: #eef2ff; border-radius: 8px; font-size: 14px; color: #333;">
      Podsumowanie: {{ weekSummary }}
    </div>
    {% endif %}

    {% if forecast %}
    <div style="margin-bottom: 24px; padding: 14px 16px; background-color: #f0f9ff; border-radius: 8px; font-size: 13px; color: #333;">
      <div style="font-weight: 600; margin-bottom: 8px;">Pogoda na 7 dni{% if forecast.locationName %} — {{ forecast.locationName }}{% endif %}</div>
      <div style="display: flex; flex-wrap: wrap; gap: 4px;">
        {% for day in forecast.days %}
        <div style="flex: 1; min-width: 65px; text-align: center; padding: 4px 2px;">
          <div style="font-size: 13px; font-weight: 600; color: #333;">{{ day.dayOfWeek }}</div>
          <div style="font-size: 11px; color: #888; margin-top: 1px;">{{ day.date.slice(5) }}</div>
          <div style="font-size: 12px; margin-top: 4px;">{{ day.condition }}</div>
          <div style="font-size: 12px; color: #444; margin-top: 2px;">{{ day.tempMax }}° / {{ day.tempMin }}°</div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if f1 %}
    <div style="margin-bottom: 24px; padding: 14px 16px; background-color: #fff5f5; border-radius: 8px; font-size: 13px; color: #333;">
      <div style="font-weight: 600; margin-bottom: 10px;">🏎️ F1 w tym tygodniu</div>
      {% for event in f1 %}
      <div{% if not loop.first %} style="margin-top: 12px;"{% endif %}>
        <div style="font-weight: 600; font-size: 14px;">{{ event.raceName }}</div>
        <div style="font-size: 12px; color: #666; margin-bottom: 6px;">{{ event.circuitName }} · {{ event.locality }}, {{ event.country }}</div>
        {% for session in event.sessions %}
        <div style="display: flex; justify-content: space-between; padding: 2px 0; font-size: 12px;">
          <span>{{ session.name }}</span>
          <span style="color: #555;">{{ session.dateTime }}</span>
        </div>
        {% endfor %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if overdue.length > 0 %}
    <div style="margin-bottom: 24px;">
      <div style="font-size: 16px; font-weight: 600; color: #c53030; margin-bottom: 10px;">Zaległe</div>
      {% for task in overdue %}
      <div style="padding: 8px 0;{% if not loop.last %} border-bottom: 1px solid #e8e8ec;{% endif %}">
        <div>
          <span style="color: {% if task.priority == 4 %}#c53030{% elif task.priority == 3 %}#dd6b20{% elif task.priority == 2 %}#3182ce{% else %}#1a1a1a{% endif %}; font-size: 8px; vertical-align: middle;">&#9679;&ensp;</span>{{ task.content }}{% if task.isRecurring %}<span style="color: #a0a0a0; font-size: 12px;"> ↻</span>{% endif %}
        </div>
        <div style="font-size: 13px; color: #888; margin-top: 2px;">
          {{ task.dueString }}{% if task.durationFormatted %} · {{ task.durationFormatted }}{% endif %}{% if task.location %} · 📍 {{ task.location }}{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% for project in projects %}
    <div style="margin-bottom: 24px;">
      <div style="font-size: 16px; font-weight: 600; color: #333; margin-bottom: 10px;">{{ project.name }}</div>
      {% for task in project.tasks %}
      <div style="padding: 8px 0;{% if not loop.last %} border-bottom: 1px solid #e8e8ec;{% endif %}">
        <div>
          <span style="color: {% if task.priority == 4 %}#c53030{% elif task.priority == 3 %}#dd6b20{% elif task.priority == 2 %}#3182ce{% else %}#1a1a1a{% endif %}; font-size: 8px; vertical-align: middle;">&#9679;&ensp;</span>{{ task.content }}{% if task.isRecurring %}<span style="color: #a0a0a0; font-size: 12px;"> ↻</span>{% endif %}
        </div>
        <div style="font-size: 13px; color: #888; margin-top: 2px;">
          {{ task.dueString }}{% if task.durationFormatted %} · {{ task.durationFormatted }}{% endif %}{% if task.location %} · 📍 {{ task.location }}{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% endfor %}

    <div style="border-top: 1px solid #e0e0e0; margin-top: 8px; padding-top: 16px; font-size: 12px; color: #b0b0b0; text-align: center;">
      Wysłano przez Taskovo z ❤️
    </div>
  </div>
</div>
