# Todoist API token (get from: Settings > Integrations > Developer)
TODOIST_API_TOKEN=your_token_here

# Resend API key (get from: https://resend.com/api-keys)
RESEND_API_KEY=your_resend_api_key_here

# Email settings — recipients are auto-discovered from Todoist project collaborators
DIGEST_FROM_EMAIL=taskovo@yourdomain.com

# Comma-separated emails to exclude from receiving digests
# DIGEST_EMAIL_BLACKLIST=someone@example.com,another@example.com

# Optional settings
# TIMEZONE=Europe/Warsaw
# DIGEST_CRON=0 19 * * 0
# STATE_DIR=/data/state
# LOG_LEVEL=info

# LLM — any OpenAI-compatible endpoint (Ollama, llama.cpp, OpenAI, Groq, etc.)
# If LLM_BASE_URL is not set, digest emails are sent without AI summary.
# LLM_BASE_URL=http://localhost:11434   # Ollama default
# LLM_API_KEY=                          # optional — local models don't need it
# LLM_MODEL=nemotron-cascade-2          # model name passed in API request
# LLM_TIMEOUT=120                        # seconds to wait for LLM response (default: 120)

# Weather forecast in digest — uses Open-Meteo (free, no API key needed)
# Option 1: Set city name — coordinates are resolved automatically via geocoding
# WEATHER_LOCATION=Warsaw
# Option 2: Set exact coordinates (overrides WEATHER_LOCATION if both are set)
# WEATHER_LATITUDE=52.23
# WEATHER_LONGITUDE=21.01

# F1 race schedule in digest — uses Jolpica API (free, no API key needed)
# Shows upcoming race weekends with all session times when enabled
# F1_SCHEDULE=true
