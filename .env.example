# Todoist API token (get from: Settings > Integrations > Developer)
TODOIST_API_TOKEN=your_token_here

# Resend API key (get from: https://resend.com/api-keys)
RESEND_API_KEY=your_resend_api_key_here

# Email settings — recipients are auto-discovered from Todoist project collaborators
DIGEST_FROM_EMAIL=taskovo@yourdomain.com

# Comma-separated emails to exclude from receiving digests
# DIGEST_EMAIL_BLACKLIST=someone@example.com,another@example.com

# Optional settings
# TIMEZONE=Europe/Warsaw
# DIGEST_CRON=0 19 * * 0
# STATE_DIR=/data/state
# LOG_LEVEL=info
